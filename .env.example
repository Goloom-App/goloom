APP_ENV=development
HTTP_ADDR=:8080
DATABASE_URL=file:./data/goloom.db
ENCRYPTION_KEY=replace-with-a-long-random-secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Per IP for unauthenticated routes (login, health-adjacent). Bearer SPA/API traffic uses RATE_LIMIT_AUTHENTICATED_PER_MINUTE (default max(300, 5×this) if unset).
RATE_LIMIT_PER_MINUTE=120
# RATE_LIMIT_AUTHENTICATED_PER_MINUTE=
SCHEDULER_POLL_INTERVAL=15s
SCHEDULER_WORKERS=4
BOOTSTRAP_ADMIN_EMAIL=admin@localhost
BOOTSTRAP_ADMIN_NAME=Local Administrator
BOOTSTRAP_ADMIN_TOKEN=replace-with-a-strong-bootstrap-token
MASTODON_APP_NAME=goloom
MASTODON_REDIRECT_URI=http://localhost:8080/v1/oauth/mastodon/callback
MASTODON_WEBSITE=
MASTODON_DEFAULT_SCOPES=read,write

OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Optional. Defaults to {PUBLIC_BASE_URL}/v1/oauth/oidc/callback — register this URL on your IdP for browser login.
OIDC_REDIRECT_URI=

# --- docker-compose-traefik.yml (production behind Traefik) ---
# HOST=app.example.com
# ENCRYPTION_KEY=replace-with-a-long-random-secret
# TRAEFIK_NETWORK=frontend
# FRONTEND_NETWORK=frontend
# PUBLIC_BASE_URL=https://app.example.com
# TRAEFIK_ENTRYPOINTS=websecure
# TRAEFIK_TLS=true
