---
const repo = 'https://github.com/Goloom-App/goloom';
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="lp-footer">
	<div class="lp-container lp-footer__inner">
		<div class="lp-brand" style="font-size:1rem;">
			<img src={`${base}favicon.svg`} alt="" width="22" height="22" />
			<span>goloom</span>
		</div>
		<nav class="lp-nav__links" style="display:flex;gap:1.4rem;flex-wrap:wrap;">
			<a href={`${base}getting-started/installation/`}>Docs</a>
			<a href={`${base}api/`}>API</a>
			<a href="#features">Features</a>
			<a href={repo}>Source</a>
			<a href={`${base}legal/`}>License</a>
		</nav>
		<span>© {year} goloom · MIT-licensed, self-hosted</span>
	</div>
</footer>
