---
const coreNodes = [
	{
		label: 'Go binary',
		desc: 'API · scheduler · embedded UI',
	},
	{
		label: 'SQLite / PostgreSQL',
		desc: 'Your choice of database backend',
	},
];
---

<section class="landing-section">
	<div class="landing-container">
		<div class="landing-section__header">
			<p class="landing-section__eyebrow">Architecture</p>
			<h2 class="landing-section__title">Simple by design</h2>
			<p class="landing-section__subtitle">
				No Kubernetes required. One process handles the core — add the AI service
				only when you need voice and campaign automation.
			</p>
		</div>
		<div class="architecture glass-panel">
			<div class="architecture__flow">
				<div class="architecture__node glass-panel">
					<p class="architecture__node-label">{coreNodes[0].label}</p>
					<p class="architecture__node-desc">{coreNodes[0].desc}</p>
				</div>
				<span class="architecture__arrow" aria-hidden="true">→</span>
				<div class="architecture__node glass-panel">
					<p class="architecture__node-label">{coreNodes[1].label}</p>
					<p class="architecture__node-desc">{coreNodes[1].desc}</p>
				</div>
			</div>
			<div class="architecture__optional">
				<span class="architecture__optional-label">Optional</span>
				<div class="architecture__node glass-panel">
					<p class="architecture__node-label">AI service</p>
					<p class="architecture__node-desc">
						Python worker for voice profiles, drafts, and campaign automation
					</p>
				</div>
			</div>
		</div>
	</div>
</section>
