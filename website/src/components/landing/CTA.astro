---
const repo = 'https://github.com/Goloom-App/goloom';
const base = import.meta.env.BASE_URL;
---

<section class="lp-section">
	<div class="lp-container">
		<div class="lp-cta">
			<h2>Self-host goloom in minutes</h2>
			<p>
				One binary, one command. Bring your own server, keep your data, and automate
				your social presence on your terms.
			</p>
			<div class="lp-cta-row">
				<a class="glow-btn" href={`${base}getting-started/installation/`}>Get started</a>
				<a class="ghost-btn" href={repo}>View on GitHub</a>
			</div>
		</div>
	</div>
</section>
