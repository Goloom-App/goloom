---
const repo = 'https://github.com/Goloom-App/goloom';
const base = import.meta.env.BASE_URL;
---

<section class="lp-section">
	<div class="lp-container">
		<div class="lp-cta">
			<h2>Run it yourself</h2>
			<p>
				One binary, one command. Your server, your data, your tokens — no account
				to create, nothing phoning home.
			</p>
			<div class="lp-cta-row">
				<a class="glow-btn" href={`${base}getting-started/installation/`}>Get started</a>
				<a class="ghost-btn" href={repo}>Source on GitHub</a>
			</div>
		</div>
	</div>
</section>
