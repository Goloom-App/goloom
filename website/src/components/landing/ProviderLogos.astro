---
const base = import.meta.env.BASE_URL;
const providers = [
	{ name: 'Mastodon', icon: `${base}icons/platforms/mastodon.svg` },
	{ name: 'Friendica', icon: `${base}icons/platforms/friendica.svg` },
	{ name: 'Bluesky', icon: `${base}icons/platforms/bluesky.svg` },
];
---

<section class="lp-section" id="providers" style="padding-block: clamp(2rem, 5vw, 3.5rem);">
	<div class="lp-container">
		<div class="lp-section__head" style="margin-bottom: 2rem;">
			<span class="lp-eyebrow">Connect your accounts</span>
			<h2>Publish across the fediverse</h2>
		</div>
		<div class="lp-providers">
			{providers.map((p) => (
				<span class="glass lp-provider">
					<img src={p.icon} alt="" width="26" height="26" />
					{p.name}
				</span>
			))}
		</div>
	</div>
</section>
