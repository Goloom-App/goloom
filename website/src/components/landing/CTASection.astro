---
const repoUrl = 'https://git.f4mily.net/goloom';
---

<section class="landing-section cta-section">
	<div class="landing-container">
		<div class="cta-section__panel glass-panel">
			<h2 class="cta-section__title">Ready to get started?</h2>
			<p class="cta-section__text">
				Install goloom in minutes, connect your accounts, and start scheduling.
				The docs walk you through configuration, first login, and deployment.
			</p>
			<div class="cta-section__actions">
				<a class="btn btn--primary" href="/docs/">Read the docs</a>
				<a class="btn btn--secondary" href="/docs/getting-started/installation/"
					>Getting started</a
				>
				<a
					class="btn btn--ghost"
					href={repoUrl}
					target="_blank"
					rel="noopener noreferrer">View on Git</a
				>
			</div>
		</div>
	</div>
</section>
