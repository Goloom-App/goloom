---
const values = [
	{
		icon: '🏠',
		title: 'Self-hosted',
		text: 'Run on your own infrastructure. Your data, your accounts, your rules — no SaaS lock-in.',
	},
	{
		icon: '⚡',
		title: 'Simple ops',
		text: 'Single Go binary with embedded UI. SQLite by default, PostgreSQL when you need it.',
	},
	{
		icon: '🔌',
		title: 'API-first',
		text: 'Full REST API for automation, AI agents, and custom integrations from day one.',
	},
];
---

<section class="landing-section">
	<div class="landing-container">
		<div class="landing-section__header">
			<p class="landing-section__eyebrow">Why goloom</p>
			<h2 class="landing-section__title">Built for operators, not marketers</h2>
			<p class="landing-section__subtitle">
				A focused tool for planning and publishing across the fediverse — without
				the bloat of enterprise social suites.
			</p>
		</div>
		<div class="value-grid">
			{
				values.map((item) => (
					<article class="value-card glass-panel">
						<div class="value-card__icon" aria-hidden="true">
							{item.icon}
						</div>
						<h3 class="value-card__title">{item.title}</h3>
						<p class="value-card__text">{item.text}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
