---
import { Image } from 'astro:assets';
import calendar from '../../assets/screenshots/content-calendar.png';
import composer from '../../assets/screenshots/composer.png';
import analytics from '../../assets/screenshots/analytics.png';

const shots = [
	{ id: 'calendar', src: calendar, title: 'Content calendar', caption: 'Schedule and reschedule across accounts' },
	{ id: 'composer', src: composer, title: 'Composer', caption: 'Per-account versions and media' },
	{ id: 'analytics', src: analytics, title: 'Analytics', caption: 'Reach, engagement and growth' },
];
---

<section class="lp-section" id="screenshots">
	<div class="lp-container">
		<div class="lp-section__head">
			<h2>Screenshots</h2>
			<p>The screens you actually work in. Click any shot to view it full size.</p>
		</div>
		<div class="lp-shots lp-shots--3">
			{shots.map((s) => (
				<figure class="glass lp-shot">
					<a href={`#shot-${s.id}`} class="lp-shot__open" aria-label={`View ${s.title} full size`}>
						<Image src={s.src} alt={s.title} widths={[420, 760]} sizes="(max-width: 860px) 100vw, 33vw" />
					</a>
					<figcaption>
						<strong>{s.title}</strong>
						<span>{s.caption}</span>
					</figcaption>
				</figure>
			))}
		</div>
	</div>
</section>

{shots.map((s) => (
	<a href="#screenshots" class="lp-lightbox" id={`shot-${s.id}`} aria-label={`Close ${s.title}`}>
		<Image src={s.src} alt={s.title} widths={[1024, 1600]} sizes="95vw" />
	</a>
))}

<style>
	.lp-shot__open {
		display: block;
		cursor: zoom-in;
	}
	.lp-lightbox {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: none;
		align-items: center;
		justify-content: center;
		padding: clamp(1rem, 4vw, 3rem);
		background: rgba(5, 6, 10, 0.88);
		backdrop-filter: blur(4px);
		cursor: zoom-out;
	}
	.lp-lightbox:target {
		display: flex;
	}
	.lp-lightbox img {
		max-width: min(1600px, 95vw);
		max-height: 90vh;
		width: auto;
		height: auto;
		border-radius: 10px;
		border: 1px solid var(--glass-border-strong);
		box-shadow: 0 24px 60px -12px rgba(0, 0, 0, 0.6);
	}
</style>
