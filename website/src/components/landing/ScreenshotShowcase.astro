---
import { Image } from 'astro:assets';
import calendar from '../../assets/screenshots/content-calendar.png';
import composer from '../../assets/screenshots/composer.png';
import analytics from '../../assets/screenshots/analytics.png';

const shots = [
	{ src: calendar, title: 'Content calendar', caption: 'Plan and reschedule across accounts' },
	{ src: composer, title: 'Composer', caption: 'Per-account versions and media' },
	{ src: analytics, title: 'Analytics', caption: 'Reach, engagement and growth' },
];
---

<section class="lp-section" id="screenshots">
	<div class="lp-container">
		<div class="lp-section__head">
			<span class="lp-eyebrow">See it in action</span>
			<h2>A calm, fast workspace</h2>
			<p>The same screens your team uses every day — planning, composing and measuring in one place.</p>
		</div>
		<div class="lp-shots lp-shots--3">
			{shots.map((s) => (
				<figure class="glass lp-shot">
					<Image src={s.src} alt={s.title} widths={[420, 760]} sizes="(max-width: 860px) 100vw, 33vw" />
					<figcaption>
						<strong>{s.title}</strong>
						<span>{s.caption}</span>
					</figcaption>
				</figure>
			))}
		</div>
	</div>
</section>
