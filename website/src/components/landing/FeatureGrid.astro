---
const features = [
	{
		title: 'Built-in MCP server',
		body: 'A Model Context Protocol server ships in the binary, so agents can drive goloom over the same tools you use by hand.',
	},
	{
		title: 'REST API & tokens',
		body: 'Everything in the UI is a team-scoped /v1 call. Bearer tokens with a full lifecycle, plus a validate-before-schedule endpoint.',
	},
	{
		title: 'OIDC sign-in',
		body: 'Plug in your identity provider for the browser UI — Authentik, Keycloak or any OpenID Connect issuer.',
	},
	{
		title: 'Media library',
		body: 'A reusable per-team media library with deduplication, so images are one click away in the composer.',
	},
	{
		title: 'AI assist (optional)',
		body: 'Off until you wire up a provider. When enabled, drafting and enhancement follow a per-team brand voice.',
	},
	{
		title: 'Audit log & encryption',
		body: 'Every team action is attributed. Provider tokens are encrypted and API tokens hashed at rest.',
	},
];
---

<section class="lp-section" id="more">
	<div class="lp-container">
		<div class="lp-section__head">
			<h2>And the parts you’ll appreciate later</h2>
			<p>Everything around scheduling posts to multiple accounts — and not much you have to grow into.</p>
		</div>
		<div class="lp-features">
			{features.map((f) => (
				<article class="glass lp-feature">
					<h3>{f.title}</h3>
					<p>{f.body}</p>
				</article>
			))}
		</div>
	</div>
</section>
