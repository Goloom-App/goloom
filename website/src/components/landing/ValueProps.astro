---
const pillars = [
	{
		title: 'One binary',
		body: 'UI and API run in a single Go process. SQLite by default — no external database to operate. Switch to PostgreSQL when you outgrow it.',
	},
	{
		title: 'Fediverse first',
		body: 'Mastodon, Bluesky and Friendica today, with OAuth onboarding and per-account publishing and metrics. More networks are in progress.',
	},
	{
		title: 'Scriptable',
		body: 'Everything in the UI is a team-scoped REST call with bearer-token auth. A built-in MCP server lets agents drive it too — both are optional.',
	},
	{
		title: 'Teams and review',
		body: 'Owner, editor and viewer roles, a review queue for approvals, and a per-team audit log that attributes every action.',
	},
];
---

<section class="lp-section" id="why">
	<div class="lp-container">
		<div class="lp-pillars">
			{pillars.map((p) => (
				<article class="glass lp-pillar">
					<h3>{p.title}</h3>
					<p>{p.body}</p>
				</article>
			))}
		</div>
	</div>
</section>
