---
const repo = 'https://github.com/Goloom-App/goloom';
const base = import.meta.env.BASE_URL;
---

<header class="lp-header">
	<div class="lp-container lp-header__inner">
		<a class="lp-brand" href={base}>
			<img src={`${base}favicon.svg`} alt="" width="30" height="30" />
			<span>goloom</span>
		</a>
		<nav class="lp-nav" aria-label="Primary">
			<div class="lp-nav__links">
				<a href="#features">Features</a>
				<a href="#screenshots">Screenshots</a>
				<a href="#architecture">Architecture</a>
				<a href={`${base}getting-started/installation/`}>Docs</a>
				<a href={`${base}api/`}>API</a>
			</div>
			<a class="ghost-btn" href={repo} style="padding:0.5rem 1rem;font-size:0.9rem;">GitHub</a>
		</nav>
	</div>
</header>
