---
const repo = 'https://github.com/Goloom-App/goloom';
const base = import.meta.env.BASE_URL;
---

<section class="lp-hero">
	<div class="lp-container lp-hero__grid">
		<div>
			<span class="lp-pill">
				<span class="dot"></span>
				MIT · single binary · SQLite by default
			</span>
			<h1>
				Schedule one post<br />
				across every account.
			</h1>
			<p class="lp-hero__sub">
				Mastodon's built-in scheduler covers one account on one server. goloom
				schedules and publishes across all of yours — Mastodon, Bluesky and
				Friendica — from one queue and calendar you host yourself. Single Go
				binary, SQLite by default, full REST API.
			</p>
			<div class="lp-cta-row">
				<a class="glow-btn" href={`${base}getting-started/installation/`}>Get started</a>
				<a class="ghost-btn" href={repo}>Source on GitHub</a>
			</div>
		</div>

		<div class="glass lp-terminal">
			<div class="lp-terminal__bar">
				<span></span><span></span><span></span>
				<span class="t-title">goloom — quickstart</span>
			</div>
			<pre><code><span class="c-comment"># One static binary — no Docker, no external database</span>
<span class="c-prompt">$</span> ENCRYPTION_KEY=$(openssl rand -hex 32) \
    BOOTSTRAP_ADMIN_TOKEN=change-me \
    ./goloom

<span class="c-comment"># UI + API on http://localhost:8080</span>
<span class="c-comment"># Prefer containers? Docker and Kubernetes work too.</span></code></pre>
		</div>
	</div>
</section>
