---
import Default from '@astrojs/starlight/components/Footer.astro';
const repo = 'https://github.com/Goloom-App/goloom';
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<Default><slot /></Default>

<div class="goloom-docs-footer">
	<a href={base}>← Back to goloom.dev</a>
	<span>© {year} goloom · <a href={repo}>Source</a> · <a href={`${base}api/`}>API reference</a> · <a href={`${base}legal/`}>License</a></span>
</div>

<style>
	.goloom-docs-footer {
		margin-top: 1.5rem;
		padding-top: 1rem;
		border-top: 1px solid var(--sl-color-hairline-shade);
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1rem;
		justify-content: space-between;
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
	}
	.goloom-docs-footer a {
		color: var(--sl-color-gray-2);
	}
</style>
