{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Both pnpm apps (frontend, website): pin-style ranges and dedupe the lockfile after every update.",
      "matchManagers": [
        "npm"
      ],
      "rangeStrategy": "replace",
      "postUpdateOptions": [
        "pnpmDedupe"
      ]
    },
    {
      "matchManagers": [
        "npm"
      ],
      "matchFileNames": [
        "frontend/package.json"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "groupName": "frontend non-major dependencies"
    },
    {
      "matchManagers": [
        "npm"
      ],
      "matchFileNames": [
        "website/package.json"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "groupName": "website non-major dependencies"
    },
    {
      "description": "Astro and Starlight are locked together by peer dependencies (Starlight requires a matching Astro major), so they must be updated in a single PR - majors included - to avoid a build that cannot install. Kept last: packageRules apply in order and the last match wins, so this overrides the website non-major group for astro packages.",
      "matchManagers": [
        "npm"
      ],
      "matchFileNames": [
        "website/package.json"
      ],
      "matchPackageNames": [
        "astro",
        "@astrojs/**"
      ],
      "groupName": "astro ecosystem"
    }
  ]
}
